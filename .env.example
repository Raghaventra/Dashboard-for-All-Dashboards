# ---------------------------------------------------------------------------
# Ultimate Dashboard - environment configuration
# Copy this file to ".env" and fill in real values for each deployment server.
# Nothing here is hardcoded in the app, so the same code runs on any server.
# ---------------------------------------------------------------------------

# Secret used to sign session cookies. CHANGE THIS to a long random string
# on every deployment. (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`)
SECRET_KEY=change-me-to-a-long-random-string

# Who is allowed to register. Only emails ending in one of these domains
# (comma-separated) can create an account.
ALLOWED_EMAIL_DOMAINS=haystackrobotics.com

# Comma-separated list of emails that automatically become admins on first
# registration. These users can manage dashboards and promote other admins.
ADMIN_EMAILS=

# Where the SQLite database lives (relative paths are resolved from the app root).
DATABASE_URL=sqlite:///./ultimate_dashboard.db

# How long (in minutes) an emailed OTP stays valid.
OTP_TTL_MINUTES=10

# Set to "true" to also print OTP codes to the server console (handy for local
# testing when SMTP is unreachable). Keep "false" in production.
DEBUG=false

# Set to "true" when served behind HTTPS (e.g. the nginx reverse proxy) so the
# session cookie is marked Secure. Keep "false" for plain-HTTP / local dev.
SESSION_HTTPS_ONLY=false

# ---- Email (SMTP) configuration -------------------------------------------
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=haystacknimbus@gmail.com
SENDER_PASSWORD=your-app-password-here

# ---- Image uploads (profile pictures, dashboard logos) --------------------
# Set S3_BUCKET to store uploads in S3 (on EC2 boto3 uses the instance IAM role
# automatically — no keys). Leave blank to store under ./uploads (local dev).
S3_BUCKET=
S3_REGION=us-east-2
S3_PREFIX=uploads
MAX_UPLOAD_MB=5
IMAGE_SIZE_PX=512
